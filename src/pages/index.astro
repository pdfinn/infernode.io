---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Screenshot from '../components/Screenshot.astro';
import Vision from '../components/Vision.astro';
import Pillars from '../components/Pillars.astro';
import Security from '../components/Security.astro';
import WhyNow from '../components/WhyNow.astro';
import NetworkDiagram from '../components/NetworkDiagram.astro';
import DistributedArch from '../components/DistributedArch.astro';
import Products from '../components/Products.astro';
import VeltroFeatures from '../components/VeltroFeatures.astro';
import UseCases from '../components/UseCases.astro';
import Contributing from '../components/Contributing.astro';
import QuickStart from '../components/QuickStart.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="InferNode — Secure AI Agent OS | Proven Isolation &amp; Post-Quantum Crypto"
  description="Run powerful AI agents without trusting them with everything. InferNode provides formally verified namespace isolation (TLA+, SPIN, CBMC) and post-quantum cryptography (ML-KEM, ML-DSA — NIST FIPS 203/204) so agents can act autonomously and safely. Open source, MIT licensed."
>
  <Nav />
  <main>
    <!-- Trust: why you can rely on it -->
    <Hero />
    <Screenshot />
    <Vision />
    <Pillars />
    <Security />
    <WhyNow />
    <!-- Freedom: what it enables -->
    <NetworkDiagram />
    <DistributedArch />
    <Contributing />
    <!-- Experience: how you use it -->
    <Products />
    <VeltroFeatures />
    <UseCases />
    <QuickStart />
  </main>
  <Footer />
</Base>
