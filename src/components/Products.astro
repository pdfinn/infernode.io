---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).products;
---

<section id="products" class="px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 text-center">
      <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">{t.eyebrow}</p>
      <h2 class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl">
        {t.title}
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-text-muted" set:html={t.intro} />
    </div>

    <div class="grid gap-8 lg:grid-cols-3">

      <!-- Veltro -->
      <div class="group relative overflow-hidden rounded-xl border border-border bg-bg-surface p-8 transition hover:border-accent/50">
        <div class="absolute top-0 right-0 h-32 w-32 bg-[radial-gradient(circle_at_top_right,_rgba(224,96,48,0.1)_0%,_transparent_70%)]"></div>
        <div class="relative">
          <div class="mb-4 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
              <span class="text-lg text-accent">&#9654;</span>
            </div>
            <h3 class="text-xl font-semibold">{t.veltroName}</h3>
          </div>
          <p class="mb-2 text-sm font-medium text-accent">{t.veltroTagline}</p>
          <p class="mb-6 text-sm leading-relaxed text-text-muted" set:html={t.veltroBody} />
          <div class="space-y-3 text-sm">
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-accent">&#8227;</span>
              <span class="text-text-muted" set:html={t.veltroBullet1} />
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-accent">&#8227;</span>
              <span class="text-text-muted" set:html={t.veltroBullet2} />
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-accent">&#8227;</span>
              <span class="text-text-muted" set:html={t.veltroBullet3} />
            </div>
          </div>
        </div>
      </div>

      <!-- Lucia -->
      <div class="group relative overflow-hidden rounded-xl border border-border bg-bg-surface p-8 transition hover:border-node-cloud/50">
        <div class="absolute top-0 right-0 h-32 w-32 bg-[radial-gradient(circle_at_top_right,_rgba(160,128,208,0.1)_0%,_transparent_70%)]"></div>
        <div class="relative">
          <div class="mb-4 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-node-cloud/10">
              <span class="text-lg text-node-cloud">&#9733;</span>
            </div>
            <h3 class="text-xl font-semibold">{t.luciaName}</h3>
          </div>
          <p class="mb-2 text-sm font-medium text-node-cloud">{t.luciaTagline}</p>
          <p class="mb-6 text-sm leading-relaxed text-text-muted" set:html={t.luciaBody} />
          <div class="space-y-3 text-sm">
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-node-cloud">&#8227;</span>
              <span class="text-text-muted" set:html={t.luciaBullet1} />
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-node-cloud">&#8227;</span>
              <span class="text-text-muted" set:html={t.luciaBullet2} />
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-node-cloud">&#8227;</span>
              <span class="text-text-muted" set:html={t.luciaBullet3} />
            </div>
          </div>
        </div>
      </div>

      <!-- Xenith -->
      <div class="group relative overflow-hidden rounded-xl border border-border bg-bg-surface p-8 transition hover:border-node-jetson/50">
        <div class="absolute top-0 right-0 h-32 w-32 bg-[radial-gradient(circle_at_top_right,_rgba(80,200,120,0.1)_0%,_transparent_70%)]"></div>
        <div class="relative">
          <div class="mb-4 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-node-jetson/10">
              <span class="text-lg text-node-jetson">&#9638;</span>
            </div>
            <h3 class="text-xl font-semibold">{t.xenithName}</h3>
          </div>
          <p class="mb-2 text-sm font-medium text-node-jetson">{t.xenithTagline}</p>
          <p class="mb-6 text-sm leading-relaxed text-text-muted" set:html={t.xenithBody} />
          <div class="space-y-3 text-sm">
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-node-jetson">&#8227;</span>
              <span class="text-text-muted" set:html={t.xenithBullet1} />
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-node-jetson">&#8227;</span>
              <span class="text-text-muted" set:html={t.xenithBullet2} />
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-node-jetson">&#8227;</span>
              <span class="text-text-muted" set:html={t.xenithBullet3} />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 rounded-xl border border-border bg-bg-surface p-6 text-center">
      <div class="flex flex-col items-center justify-center gap-2 sm:flex-row sm:gap-4">
        <span class="font-mono text-sm text-accent">;</span>
        <span class="text-sm text-text-muted" set:html={t.foundation} />
      </div>
    </div>
  </div>
</section>
