---
import { useTranslations, p, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).vision;
---

<section id="vision" class="px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-3xl">
    <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">{t.eyebrow}</p>
    <h2 class="mb-12 text-3xl font-bold tracking-tight sm:text-4xl" set:html={t.title} />

    <div class="space-y-6 text-lg leading-relaxed text-text-muted">
      <p>{t.p1}</p>
      <p set:html={t.p2} />
      <p class="text-text text-xl font-medium">{t.p3}</p>
      <p set:html={t.p4} />
      <p set:html={t.p5} />
      <p>
        <a href={p('/manifesto', lang)} class="text-accent transition hover:text-accent-glow" set:html={t.link} />
      </p>
    </div>
  </div>
</section>
