---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).distributedArch;
---

<section id="distributed" class="px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 text-center">
      <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">
        {t.eyebrow}
      </p>
      <h2 class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl">
        {t.title}
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-text-muted" set:html={t.intro} />
    </div>

    <!-- Diagram 1: Hot-loading modules -->
    <div class="mb-20">
      <h3 class="mb-8 text-center text-xl font-semibold">
        {t.hotloadTitle}
      </h3>

      <div class="mx-auto max-w-3xl">
        <svg viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
          <g>
            <rect x="20" y="80" rx="12" width="200" height="140" class="fill-bg-surface stroke-node-laptop/50" stroke-width="1.5" />
            <text x="120" y="112" text-anchor="middle" class="fill-node-laptop text-xs font-medium" font-family="var(--font-family-mono)">{t.hotloadDevLaptop}</text>
            <rect x="48" y="130" rx="6" width="144" height="36" class="fill-bg stroke-node-laptop/30" stroke-width="1" />
            <text x="120" y="152" text-anchor="middle" class="fill-node-laptop text-[10px]" font-family="var(--font-family-mono)">sensor-filter.dis</text>
            <text x="120" y="194" text-anchor="middle" class="fill-text-muted text-[10px]" font-family="var(--font-family-sans)">{t.hotloadWriteOnce}</text>
            <circle cx="28" cy="88" r="4" class="fill-node-laptop">
              <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite" />
            </circle>
          </g>

          <g>
            <line x1="220" y1="148" x2="310" y2="108" class="stroke-accent/50" stroke-width="1.5">
              <animate attributeName="stroke-dashoffset" values="20;0" dur="1.5s" repeatCount="indefinite" />
            </line>
            <line x1="220" y1="148" x2="310" y2="108" class="stroke-accent/30" stroke-width="1.5" stroke-dasharray="4 4">
              <animate attributeName="stroke-dashoffset" values="8;0" dur="1.5s" repeatCount="indefinite" />
            </line>
            <circle r="5" class="fill-accent">
              <animateMotion dur="2s" repeatCount="indefinite" path="M220,148 L310,108" />
            </circle>
          </g>

          <g>
            <line x1="220" y1="152" x2="310" y2="208" class="stroke-accent/50" stroke-width="1.5">
              <animate attributeName="stroke-dashoffset" values="20;0" dur="1.8s" repeatCount="indefinite" />
            </line>
            <line x1="220" y1="152" x2="310" y2="208" class="stroke-accent/30" stroke-width="1.5" stroke-dasharray="4 4">
              <animate attributeName="stroke-dashoffset" values="8;0" dur="1.8s" repeatCount="indefinite" />
            </line>
            <circle r="5" class="fill-accent">
              <animateMotion dur="2.3s" repeatCount="indefinite" path="M220,152 L310,208" />
            </circle>
          </g>

          <g>
            <rect x="310" y="50" rx="12" width="200" height="110" class="fill-bg-surface stroke-node-jetson/50" stroke-width="1.5" />
            <text x="410" y="80" text-anchor="middle" class="fill-node-jetson text-xs font-medium" font-family="var(--font-family-mono)">{t.hotloadJetson}</text>
            <rect x="338" y="96" rx="6" width="144" height="36" class="fill-bg stroke-node-jetson/30" stroke-width="1" />
            <text x="410" y="112" text-anchor="middle" class="fill-node-jetson text-[10px]" font-family="var(--font-family-mono)">sensor-filter.dis</text>
            <text x="410" y="126" text-anchor="middle" class="fill-accent text-[9px]" font-family="var(--font-family-mono)">{t.hotloadLoaded}</text>
            <circle cx="318" cy="58" r="4" class="fill-node-jetson">
              <animate attributeName="opacity" values="1;0.3;1" dur="2.5s" repeatCount="indefinite" />
            </circle>
          </g>

          <g>
            <rect x="310" y="175" rx="12" width="200" height="110" class="fill-bg-surface stroke-node-rpi/50" stroke-width="1.5" />
            <text x="410" y="205" text-anchor="middle" class="fill-node-rpi text-xs font-medium" font-family="var(--font-family-mono)">{t.hotloadRpi}</text>
            <rect x="338" y="218" rx="6" width="144" height="36" class="fill-bg stroke-node-rpi/30" stroke-width="1" />
            <text x="410" y="234" text-anchor="middle" class="fill-node-rpi text-[10px]" font-family="var(--font-family-mono)">sensor-filter.dis</text>
            <text x="410" y="248" text-anchor="middle" class="fill-accent text-[9px]" font-family="var(--font-family-mono)">{t.hotloadLoaded}</text>
            <circle cx="318" cy="183" r="4" class="fill-node-rpi">
              <animate attributeName="opacity" values="1;0.3;1" dur="2.2s" repeatCount="indefinite" />
            </circle>
          </g>

          <g>
            <rect x="560" y="80" rx="12" width="220" height="140" class="fill-bg-surface stroke-border" stroke-width="1" />
            <text x="670" y="112" text-anchor="middle" class="fill-text text-[11px] font-medium" font-family="var(--font-family-sans)">{t.hotloadResultTitle}</text>
            <text x="670" y="138" text-anchor="middle" class="fill-text-muted text-[10px]" font-family="var(--font-family-sans)">{t.hotloadResult1}</text>
            <text x="670" y="154" text-anchor="middle" class="fill-text-muted text-[10px]" font-family="var(--font-family-sans)">{t.hotloadResult2}</text>
            <text x="670" y="178" text-anchor="middle" class="fill-accent text-[10px] font-medium" font-family="var(--font-family-sans)">{t.hotloadResult3}</text>
            <text x="670" y="198" text-anchor="middle" class="fill-accent text-[10px] font-medium" font-family="var(--font-family-sans)">{t.hotloadResult4}</text>
          </g>
        </svg>
      </div>

      <!-- Terminal example -->
      <div class="mx-auto mt-6 max-w-2xl rounded-xl border border-border bg-bg-surface font-mono text-sm overflow-hidden">
        <div class="flex items-center gap-2 border-b border-border px-4 py-2">
          <div class="h-2.5 w-2.5 rounded-full bg-node-rpi/60"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-node-llm/60"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-node-jetson/60"></div>
          <span class="ml-2 text-xs text-text-muted">{t.hotloadTermLabel}</span>
        </div>
        <div class="p-4 space-y-1">
          <div><span class="text-accent">;</span><span class="text-text"> bind /n/devbox/dis/sensor-filter.dis /dis/sensor-filter.dis</span></div>
          <div><span class="text-text-muted">{t.hotloadTermNote1}</span></div>
          <div><span class="text-text-muted">{t.hotloadTermNote2}</span></div>
          <div><span class="text-text-muted">{t.hotloadTermNote3}</span></div>
        </div>
      </div>

      <div class="mx-auto mt-6 grid max-w-2xl gap-4 sm:grid-cols-2">
        <div class="rounded-lg border border-border/50 bg-bg-surface/50 px-5 py-4">
          <p class="mb-1 text-xs font-medium text-accent">{t.hotloadDevsLabel}</p>
          <p class="text-xs leading-relaxed text-text-muted" set:html={t.hotloadDevsBody} />
        </div>
        <div class="rounded-lg border border-border/50 bg-bg-surface/50 px-5 py-4">
          <p class="mb-1 text-xs font-medium text-accent">{t.hotloadPracticeLabel}</p>
          <p class="text-xs leading-relaxed text-text-muted" set:html={t.hotloadPracticeBody} />
        </div>
      </div>
    </div>

    <div class="mx-auto mb-20 h-px w-32 bg-border"></div>

    <!-- Diagram 2: Remote execution, local display -->
    <div>
      <h3 class="mb-8 text-center text-xl font-semibold">
        {t.remoteTitle}
      </h3>

      <div class="mx-auto max-w-3xl">
        <svg viewBox="0 0 800 280" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
          <g>
            <rect x="20" y="60" rx="12" width="240" height="160" class="fill-bg-surface stroke-node-jetson/50" stroke-width="1.5" />
            <text x="140" y="90" text-anchor="middle" class="fill-node-jetson text-xs font-medium" font-family="var(--font-family-mono)">{t.remoteGpu}</text>

            <rect x="44" y="108" rx="4" width="90" height="24" class="fill-bg stroke-node-jetson/30" stroke-width="1" />
            <text x="89" y="124" text-anchor="middle" class="fill-node-jetson text-[9px]" font-family="var(--font-family-mono)">{t.remoteLlm}</text>

            <rect x="144" y="108" rx="4" width="90" height="24" class="fill-bg stroke-node-jetson/30" stroke-width="1" />
            <text x="189" y="124" text-anchor="middle" class="fill-node-jetson text-[9px]" font-family="var(--font-family-mono)">{t.remoteAnalysis}</text>

            <rect x="44" y="142" rx="4" width="90" height="24" class="fill-bg stroke-node-llm/30" stroke-width="1" />
            <text x="89" y="158" text-anchor="middle" class="fill-node-llm text-[9px]" font-family="var(--font-family-mono)">{t.remoteTraining}</text>

            <text x="140" y="194" text-anchor="middle" class="fill-text-muted text-[10px]" font-family="var(--font-family-sans)">{t.remoteHeavy}</text>

            <circle cx="28" cy="68" r="4" class="fill-node-jetson">
              <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite" />
            </circle>
          </g>

          <g>
            <line x1="260" y1="125" x2="380" y2="105" class="stroke-node-laptop/40" stroke-width="1.5" stroke-dasharray="4 4">
              <animate attributeName="stroke-dashoffset" values="0;-8" dur="1s" repeatCount="indefinite" />
            </line>
            <text x="320" y="98" text-anchor="middle" class="fill-text-muted text-[8px]" font-family="var(--font-family-mono)">{t.remoteInputs}</text>

            <line x1="380" y1="145" x2="260" y2="165" class="stroke-accent/40" stroke-width="1.5" stroke-dasharray="4 4">
              <animate attributeName="stroke-dashoffset" values="0;8" dur="1s" repeatCount="indefinite" />
            </line>
            <text x="320" y="180" text-anchor="middle" class="fill-text-muted text-[8px]" font-family="var(--font-family-mono)">{t.remoteResults}</text>

            <circle r="4" class="fill-node-laptop/70">
              <animateMotion dur="1.5s" repeatCount="indefinite" path="M380,105 L260,125" />
            </circle>
            <circle r="4" class="fill-accent/70">
              <animateMotion dur="1.5s" repeatCount="indefinite" path="M260,165 L380,145" />
            </circle>
          </g>

          <g>
            <rect x="380" y="60" rx="12" width="240" height="160" class="fill-bg-surface stroke-node-laptop/50" stroke-width="1.5" />
            <text x="500" y="90" text-anchor="middle" class="fill-node-laptop text-xs font-medium" font-family="var(--font-family-mono)">{t.remoteLaptop}</text>

            <rect x="410" y="108" rx="6" width="180" height="72" class="fill-bg stroke-node-laptop/30" stroke-width="1" />
            <text x="500" y="134" text-anchor="middle" class="fill-text text-[10px]" font-family="var(--font-family-sans)">{t.remoteDisplay1}</text>
            <text x="500" y="150" text-anchor="middle" class="fill-text text-[10px]" font-family="var(--font-family-sans)">{t.remoteDisplay2}</text>
            <text x="500" y="170" text-anchor="middle" class="fill-accent text-[9px] font-medium" font-family="var(--font-family-mono)">{t.remoteDisplay3}</text>

            <text x="500" y="204" text-anchor="middle" class="fill-text-muted text-[10px]" font-family="var(--font-family-sans)">{t.remoteInteract}</text>

            <circle cx="388" cy="68" r="4" class="fill-node-laptop">
              <animate attributeName="opacity" values="1;0.3;1" dur="2.5s" repeatCount="indefinite" />
            </circle>
          </g>

          <rect x="660" y="110" rx="8" width="120" height="60" class="fill-bg-surface stroke-border" stroke-width="1" />
          <text x="720" y="135" text-anchor="middle" class="fill-text-muted text-[10px]" font-family="var(--font-family-sans)">{t.remoteConnected}</text>
          <text x="720" y="155" text-anchor="middle" class="fill-accent text-xs font-medium" font-family="var(--font-family-mono)">{t.remote9p}</text>
        </svg>
      </div>

      <div class="mx-auto mt-6 max-w-2xl rounded-xl border border-border bg-bg-surface font-mono text-sm overflow-hidden">
        <div class="flex items-center gap-2 border-b border-border px-4 py-2">
          <div class="h-2.5 w-2.5 rounded-full bg-node-rpi/60"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-node-llm/60"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-node-jetson/60"></div>
          <span class="ml-2 text-xs text-text-muted">{t.remoteTermLabel}</span>
        </div>
        <div class="p-4 space-y-1">
          <div><span class="text-accent">;</span><span class="text-text"> import tcp!gpuserver!9999 /n/remote</span></div>
          <div><span class="text-accent">;</span><span class="text-text"> mount /n/remote /mnt/compute</span></div>
          <div><span class="text-accent">;</span><span class="text-text"> /mnt/compute/bin/analyse -data /n/local/dataset.csv</span></div>
          <div><span class="text-text-muted">{t.remoteTermNote1}</span></div>
          <div><span class="text-text-muted">{t.remoteTermNote2}</span></div>
        </div>
      </div>

      <div class="mx-auto mt-6 grid max-w-2xl gap-4 sm:grid-cols-2">
        <div class="rounded-lg border border-border/50 bg-bg-surface/50 px-5 py-4">
          <p class="mb-1 text-xs font-medium text-accent">{t.remoteDevsLabel}</p>
          <p class="text-xs leading-relaxed text-text-muted" set:html={t.remoteDevsBody} />
        </div>
        <div class="rounded-lg border border-border/50 bg-bg-surface/50 px-5 py-4">
          <p class="mb-1 text-xs font-medium text-accent">{t.remotePracticeLabel}</p>
          <p class="text-xs leading-relaxed text-text-muted" set:html={t.remotePracticeBody} />
        </div>
      </div>
    </div>
  </div>
</section>
