---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).networkDiagram;
---

<section id="how-it-works" class="px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 text-center">
      <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">
        {t.eyebrow}
      </p>
      <h2 class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl">
        {t.title}
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-text-muted" set:html={t.intro} />
    </div>

    <!-- Diagram -->
    <div class="mx-auto max-w-3xl">
      <svg viewBox="0 0 800 520" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <line x1="200" y1="140" x2="400" y2="280" class="stroke-node-laptop/30" stroke-width="1.5">
          <animate attributeName="stroke-opacity" values="0.15;0.4;0.15" dur="3s" repeatCount="indefinite" />
        </line>
        <line x1="600" y1="140" x2="400" y2="280" class="stroke-node-jetson/30" stroke-width="1.5">
          <animate attributeName="stroke-opacity" values="0.15;0.4;0.15" dur="3.5s" repeatCount="indefinite" />
        </line>
        <line x1="660" y1="420" x2="400" y2="280" class="stroke-node-rpi/30" stroke-width="1.5">
          <animate attributeName="stroke-opacity" values="0.15;0.4;0.15" dur="2.8s" repeatCount="indefinite" />
        </line>
        <line x1="400" y1="60" x2="400" y2="280" class="stroke-node-cloud/30" stroke-width="1.5" stroke-dasharray="6 4">
          <animate attributeName="stroke-opacity" values="0.1;0.3;0.1" dur="4s" repeatCount="indefinite" />
        </line>
        <line x1="140" y1="420" x2="400" y2="280" class="stroke-node-llm/30" stroke-width="1.5">
          <animate attributeName="stroke-opacity" values="0.15;0.4;0.15" dur="3.2s" repeatCount="indefinite" />
        </line>

        <g>
          <rect x="310" y="20" rx="12" width="180" height="56" class="fill-bg-surface stroke-node-cloud/40" stroke-width="1.5" stroke-dasharray="5 3" />
          <text x="400" y="44" text-anchor="middle" class="fill-node-cloud text-xs font-medium" font-family="var(--font-family-mono)">Cloud GPU</text>
          <text x="400" y="62" text-anchor="middle" class="fill-text-muted text-[10px]" font-family="var(--font-family-mono)">/n/compute</text>
          <text x="498" y="44" text-anchor="start" class="fill-text-muted text-[10px] italic" font-family="var(--font-family-sans)">{t.optional}</text>
        </g>

        <g>
          <rect x="110" y="110" rx="12" width="180" height="56" class="fill-bg-surface stroke-node-laptop/50" stroke-width="1.5" />
          <text x="200" y="134" text-anchor="middle" class="fill-node-laptop text-xs font-medium" font-family="var(--font-family-mono)">Laptop</text>
          <text x="200" y="152" text-anchor="middle" class="fill-text-muted text-[10px]" font-family="var(--font-family-mono)">/n/docs  /n/code</text>
          <circle cx="118" cy="118" r="4" class="fill-node-laptop">
            <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite" />
          </circle>
        </g>

        <g>
          <rect x="510" y="110" rx="12" width="180" height="56" class="fill-bg-surface stroke-node-jetson/50" stroke-width="1.5" />
          <text x="600" y="134" text-anchor="middle" class="fill-node-jetson text-xs font-medium" font-family="var(--font-family-mono)">Jetson</text>
          <text x="600" y="152" text-anchor="middle" class="fill-text-muted text-[10px]" font-family="var(--font-family-mono)">/n/gpu  /n/inference</text>
          <circle cx="518" cy="118" r="4" class="fill-node-jetson">
            <animate attributeName="opacity" values="1;0.3;1" dur="2.5s" repeatCount="indefinite" />
          </circle>
        </g>

        <g>
          <rect x="300" y="248" rx="16" width="200" height="64" class="fill-bg-surface stroke-accent/60" stroke-width="2" />
          <text x="400" y="274" text-anchor="middle" class="fill-accent text-sm font-semibold" font-family="var(--font-family-sans)">Veltro</text>
          <text x="400" y="296" text-anchor="middle" class="fill-text-muted text-xs" font-family="var(--font-family-sans)">{lang === 'zh' ? 'AI 智能体' : 'AI Agent'}</text>
          <rect x="300" y="248" rx="16" width="200" height="64" fill="none" class="stroke-accent/20" stroke-width="6">
            <animate attributeName="stroke-opacity" values="0.1;0.25;0.1" dur="2s" repeatCount="indefinite" />
          </rect>
        </g>

        <g>
          <rect x="50" y="390" rx="12" width="180" height="56" class="fill-bg-surface stroke-node-llm/50" stroke-width="1.5" />
          <text x="140" y="414" text-anchor="middle" class="fill-node-llm text-xs font-medium" font-family="var(--font-family-mono)">{lang === 'zh' ? '本地 LLM' : 'Local LLM'}</text>
          <text x="140" y="432" text-anchor="middle" class="fill-text-muted text-[10px]" font-family="var(--font-family-mono)">/n/llm</text>
          <circle cx="58" cy="398" r="4" class="fill-node-llm">
            <animate attributeName="opacity" values="1;0.3;1" dur="3s" repeatCount="indefinite" />
          </circle>
        </g>

        <g>
          <rect x="570" y="390" rx="12" width="180" height="56" class="fill-bg-surface stroke-node-rpi/50" stroke-width="1.5" />
          <text x="660" y="414" text-anchor="middle" class="fill-node-rpi text-xs font-medium" font-family="var(--font-family-mono)">Raspberry Pi</text>
          <text x="660" y="432" text-anchor="middle" class="fill-text-muted text-[10px]" font-family="var(--font-family-mono)">/n/sensors</text>
          <circle cx="578" cy="398" r="4" class="fill-node-rpi">
            <animate attributeName="opacity" values="1;0.3;1" dur="2.2s" repeatCount="indefinite" />
          </circle>
        </g>

        <text x="400" y="500" text-anchor="middle" class="fill-text-muted text-xs" font-family="var(--font-family-sans)">
          {t.caption}
        </text>
      </svg>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-3">
      <div class="rounded-xl border border-border bg-bg-surface p-6">
        <h3 class="mb-2 font-semibold">{t.c1Title}</h3>
        <p class="text-sm leading-relaxed text-text-muted" set:html={t.c1Body} />
      </div>
      <div class="rounded-xl border border-border bg-bg-surface p-6">
        <h3 class="mb-2 font-semibold">{t.c2Title}</h3>
        <p class="text-sm leading-relaxed text-text-muted" set:html={t.c2Body} />
      </div>
      <div class="rounded-xl border border-border bg-bg-surface p-6">
        <h3 class="mb-2 font-semibold">{t.c3Title}</h3>
        <p class="text-sm leading-relaxed text-text-muted" set:html={t.c3Body} />
      </div>
    </div>
  </div>
</section>
