---
---

<section id="quickstart" class="px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-3xl">
    <div class="mb-12 text-center">
      <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">Quick Start</p>
      <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">
        Launch the app or build from source.
      </h2>
      <p class="text-text-muted">On macOS, download and run. On Linux, download or build from source. Either way&mdash;under a minute.</p>
    </div>

    <!-- macOS — app card -->
    <div class="rounded-xl border border-border bg-bg-surface p-8">
      <div class="flex flex-col items-center gap-6 sm:flex-row">
        <img src="/infernode-icon.png" alt="InferNode app icon" class="h-24 w-24 rounded-2xl" />
        <div>
          <h3 class="mb-1 text-lg font-semibold">InferNode.app</h3>
          <p class="mb-3 text-sm text-text-muted">
            macOS (Apple Silicon) &mdash; open the DMG, drag to Applications, launch.
          </p>
          <a
            href="https://github.com/infernode-os/infernode/releases/tag/v0.1"
            class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-2 text-sm font-medium text-white transition hover:bg-accent-glow"
            target="_blank"
            rel="noopener"
          >
            Download v0.1
          </a>
        </div>
      </div>
    </div>

    <!-- Linux — prebuilt or build from source -->
    <div class="mt-6 rounded-xl border border-border bg-bg-surface font-mono text-sm overflow-hidden">
      <div class="flex items-center justify-between border-b border-border px-4 py-3">
        <div class="flex items-center gap-2">
          <div class="h-3 w-3 rounded-full bg-node-rpi/60"></div>
          <div class="h-3 w-3 rounded-full bg-node-llm/60"></div>
          <div class="h-3 w-3 rounded-full bg-node-jetson/60"></div>
          <span class="ml-2 text-xs text-text-muted">Linux &mdash; download or build from source</span>
        </div>
        <a
          href="https://github.com/infernode-os/infernode/releases/download/v0.1/infernode-0.1-linux-amd64.tar.gz"
          class="text-xs text-accent hover:text-accent-glow transition font-sans"
          target="_blank"
          rel="noopener"
        >
          Download v0.1 tarball (amd64)
        </a>
      </div>
      <div class="p-5 space-y-1">
        <div class="text-text-muted"># Clone the repository</div>
        <div>
          <span class="text-node-jetson">$</span>
          <span class="text-text"> git clone https://github.com/infernode-os/infernode.git</span>
        </div>
        <div>
          <span class="text-node-jetson">$</span>
          <span class="text-text"> cd infernode</span>
        </div>
        <div class="mt-3"></div>

        <div class="text-text-muted"># Build for your platform</div>
        <div>
          <span class="text-node-jetson">$</span>
          <span class="text-text"> ./build-linux-amd64.sh</span>
          <span class="text-text-muted">  # or build-linux-arm64.sh</span>
        </div>
        <div class="mt-3"></div>

        <div class="text-text-muted"># Run</div>
        <div>
          <span class="text-node-jetson">$</span>
          <span class="text-text"> ./emu/Linux/o.emu -r.</span>
        </div>
        <div class="mt-3"></div>

        <div class="text-text-muted"># You're in Inferno&reg;</div>
        <div>
          <span class="text-accent">;</span>
          <span class="text-text"> ls /dis</span>
        </div>
        <div class="text-text-muted pl-2">0intro.dis  acme.dis  asm.dis  ...</div>
        <div>
          <span class="text-accent">;</span>
          <span class="text-text"> cat /dev/sysctl</span>
        </div>
        <div class="text-text-muted pl-2">Fourth Edition (20120928)</div>
      </div>
    </div>

    <!-- Platform badges -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <div class="flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm text-text-muted">
        <span class="font-mono text-node-laptop">x86_64</span> Linux
      </div>
      <div class="flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm text-text-muted">
        <span class="font-mono text-node-jetson">ARM64</span> Linux (Jetson, RPi)
      </div>
      <div class="flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm text-text-muted">
        <span class="font-mono text-node-rpi">ARM64</span> macOS (Apple Silicon)
      </div>
      <div class="flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm text-text-muted opacity-50">
        <span class="font-mono text-node-cloud">x86_64</span> Windows (coming soon)
      </div>
    </div>
  </div>
</section>
