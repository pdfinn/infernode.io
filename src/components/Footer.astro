---
import { useTranslations, p, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).footer;
---

<footer class="border-t border-border px-6 py-12">
  <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-6 sm:flex-row">
    <div class="flex items-center gap-2 text-sm text-text-muted">
      <img src="/infernode-icon.png" alt="InferNode logo" class="h-5 w-5 object-contain" />
      <span>InferNode</span>
      <span class="mx-2 text-border">|</span>
      <span>{t.license}</span>
    </div>
    <div class="flex items-center gap-6 text-sm text-text-muted">
      <img
        src="/9p-inside.png"
        alt="9P Inside — InferNode uses the 9P protocol to expose every resource as a file"
        title="9P Inside"
        class="h-8 opacity-70 hover:opacity-100 transition"
      />
      <a
        href="https://github.com/infernode-os/infernode"
        class="transition hover:text-text"
        target="_blank"
        rel="noopener"
      >
        {t.github}
      </a>
      <a href={p('/veltro', lang)} class="transition hover:text-text">
        {t.veltro}
      </a>
      <a href={p('/compare', lang)} class="transition hover:text-text">
        {t.compare}
      </a>
      <a href={p('/manifesto', lang)} class="transition hover:text-text">
        {t.manifesto}
      </a>
    </div>
  </div>
</footer>
