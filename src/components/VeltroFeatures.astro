---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).veltroFeatures;

const features = [
  { icon: 'ph ph-prohibit', color: 'accent', title: t.f1Title, body: t.f1Body },
  { icon: 'ph ph-git-branch', color: 'node-rpi', title: t.f2Title, body: t.f2Body },
  { icon: 'ph ph-plug', color: 'node-cloud', title: t.f3Title, body: t.f3Body },
  { icon: 'ph ph-graph', color: 'node-jetson', title: t.f4Title, body: t.f4Body },
];
---

<section class="px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mb-12 text-center">
      <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">{t.eyebrow}</p>
      <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">
        {t.title}
      </h2>
      <p class="mx-auto max-w-2xl text-text-muted" set:html={t.intro} />
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {features.map((f) => (
        <div class={`group rounded-xl border border-border bg-bg-surface p-8 transition hover:border-${f.color}/40`}>
          <div class="mb-4 flex items-center gap-3">
            <div class={`flex h-10 w-10 items-center justify-center rounded-lg bg-${f.color}/10`}>
              <i class={`${f.icon} text-lg text-${f.color}`} />
            </div>
            <h3 class="text-lg font-semibold">{f.title}</h3>
          </div>
          <p class="text-sm leading-relaxed text-text-muted" set:html={f.body} />
        </div>
      ))}
    </div>
  </div>
</section>
