---
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { useTranslations, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;
const meta = useTranslations(lang).meta.security;
const t = useTranslations(lang).securityPage;
---

<Base title={meta.title} description={meta.description} lang={lang}>
  <Nav lang={lang} />
  <main>

    <!-- Hero -->
    <section class="relative flex items-center justify-center px-6 pt-40 pb-24 lg:pb-32">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(224,96,48,0.06)_0%,_transparent_70%)]"></div>
      <div class="relative mx-auto max-w-3xl text-center">
        <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">{t.eyebrow}</p>
        <h1 class="mb-6 text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl" set:html={t.title} />
        <p class="mx-auto max-w-2xl text-lg leading-relaxed text-text-muted" set:html={t.intro} />

        <div class="mt-10 flex flex-wrap justify-center gap-8 text-sm">
          <div class="flex flex-col items-center">
            <span class="text-2xl font-semibold text-text">{t.stat1}</span>
            <span class="text-text-muted">{t.stat1Label}</span>
          </div>
          <div class="hidden h-8 w-px bg-border sm:block self-center"></div>
          <div class="flex flex-col items-center">
            <span class="text-2xl font-semibold text-text">{t.stat2}</span>
            <span class="text-text-muted">{t.stat2Label}</span>
          </div>
          <div class="hidden h-8 w-px bg-border sm:block self-center"></div>
          <div class="flex flex-col items-center">
            <span class="text-2xl font-semibold text-text">{t.stat3}</span>
            <span class="text-text-muted">{t.stat3Label}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="px-6 py-16 border-t border-border">
      <div class="mx-auto max-w-5xl">
        <div class="grid gap-12 lg:grid-cols-2 items-center">
          <div>
            <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">{t.archEyebrow}</p>
            <h2 class="mb-6 text-3xl font-bold tracking-tight" set:html={t.archTitle} />
            <div class="space-y-4 text-text-muted">
              <p set:html={t.archP1} />
              <p set:html={t.archP2} />
              <p>{t.archP3}</p>
            </div>
          </div>

          <div class="rounded-xl border border-border bg-bg-surface font-mono text-sm overflow-hidden">
            <div class="flex items-center gap-2 border-b border-border px-4 py-3">
              <div class="h-3 w-3 rounded-full bg-node-rpi/60"></div>
              <div class="h-3 w-3 rounded-full bg-node-llm/60"></div>
              <div class="h-3 w-3 rounded-full bg-node-jetson/60"></div>
              <span class="ml-2 text-xs text-text-muted">{t.termLabel}</span>
            </div>
            <div class="p-5 space-y-3">
              <div><span class="text-accent">;</span><span class="text-text-muted"> {t.term1}</span></div>
              <div><span class="text-accent">;</span><span class="text-text"> mount /n/docs /agent/data</span></div>
              <div><span class="text-accent">;</span><span class="text-text"> mount /n/llm /agent/llm</span></div>
              <div class="mt-4"><span class="text-accent">;</span><span class="text-text-muted"> {t.term2}</span></div>
              <div><span class="text-accent">;</span><span class="text-text"> ls /agent/</span></div>
              <div><span class="text-node-laptop">data/</span><span class="text-node-llm ml-4">llm/</span></div>
              <div class="mt-4"><span class="text-accent">;</span><span class="text-text-muted"> {t.term3}</span></div>
              <div><span class="text-accent">;</span><span class="text-text"> cat /home/.ssh/id_rsa</span></div>
              <div class="text-text-muted italic">&nbsp;&nbsp;{t.term4}</div>
              <div class="mt-4"><span class="text-accent">;</span><span class="text-text-muted"> {t.term5}</span></div>
              <div><span class="text-accent">;</span><span class="text-text"> cat /etc/passwd</span></div>
              <div class="text-text-muted italic">&nbsp;&nbsp;{t.term6}</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Proof -->
    <section class="px-6 py-16 border-t border-border">
      <div class="mx-auto max-w-5xl">
        <div class="mb-12 text-center">
          <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">{t.proofEyebrow}</p>
          <h2 class="mb-4 text-3xl font-bold tracking-tight">{t.proofTitle}</h2>
          <p class="mx-auto max-w-2xl text-text-muted">{t.proofIntro}</p>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          <div class="rounded-xl border border-border bg-bg-surface p-6">
            <div class="mb-4">
              <span class="inline-flex items-center rounded-lg bg-accent/10 px-3 py-1 text-xs font-semibold text-accent">{t.tla}</span>
            </div>
            <h3 class="mb-3 font-semibold">{t.tlaTitle}</h3>
            <p class="text-sm leading-relaxed text-text-muted">{t.tlaBody}</p>
          </div>

          <div class="rounded-xl border border-border bg-bg-surface p-6">
            <div class="mb-4">
              <span class="inline-flex items-center rounded-lg bg-node-rpi/10 px-3 py-1 text-xs font-semibold text-node-rpi">{t.spin}</span>
            </div>
            <h3 class="mb-3 font-semibold">{t.spinTitle}</h3>
            <p class="text-sm leading-relaxed text-text-muted">{t.spinBody}</p>
          </div>

          <div class="rounded-xl border border-border bg-bg-surface p-6">
            <div class="mb-4">
              <span class="inline-flex items-center rounded-lg bg-node-jetson/10 px-3 py-1 text-xs font-semibold text-node-jetson">{t.cbmc}</span>
            </div>
            <h3 class="mb-3 font-semibold">{t.cbmcTitle}</h3>
            <p class="text-sm leading-relaxed text-text-muted">{t.cbmcBody}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Post-Quantum Crypto -->
    <section class="px-6 py-16 border-t border-border">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 text-center">
          <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">{t.pqEyebrow}</p>
          <h2 class="text-3xl font-bold tracking-tight">{t.pqTitle}</h2>
        </div>
        <div class="rounded-xl border border-border bg-bg-surface p-8">
          <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:gap-8">
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-accent/10">
              <span class="text-xl text-accent">&#9883;</span>
            </div>
            <div>
              <div class="mb-3 flex flex-wrap items-center gap-3">
                <h3 class="text-lg font-semibold">{t.pqInner}</h3>
                <span class="rounded-full border border-accent/40 px-2.5 py-0.5 text-xs font-medium text-accent">{t.pqBadge}</span>
              </div>
              <p class="mb-4 text-sm leading-relaxed text-text-muted" set:html={t.pqP1} />
              <p class="text-sm leading-relaxed text-text-muted">{t.pqP2}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 py-16 border-t border-border">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-4 text-2xl font-bold">{t.ctaTitle}</h2>
        <p class="mb-8 text-text-muted">{t.ctaBody}</p>
        <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href="https://github.com/infernode-os/infernode/tree/main/formal-verification"
            class="inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white transition hover:bg-accent/80"
            target="_blank"
            rel="noopener"
            set:html={t.ctaPrimary}
          />
          <a
            href="https://github.com/infernode-os/infernode"
            class="inline-flex items-center gap-2 rounded-lg border border-border px-6 py-3 text-sm font-medium text-text-muted transition hover:border-accent hover:text-text"
            target="_blank"
            rel="noopener"
            set:html={t.ctaSecondary}
          />
        </div>
      </div>
    </section>

  </main>
  <Footer lang={lang} />
</Base>
