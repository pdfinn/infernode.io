---
import { useTranslations, p, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).hero;
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden px-6 pt-20">
  <!-- Subtle radial glow -->
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(224,96,48,0.08)_0%,_transparent_70%)]"></div>

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <p class="mb-6 text-sm font-medium tracking-widest uppercase text-text-muted">
      {t.eyebrow}
    </p>

    <h1 class="mb-8 text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
      {t.title1}<br />
      <span class="text-accent">{t.title2}</span>
    </h1>

    <p class="mx-auto mb-12 max-w-2xl text-lg leading-relaxed text-text-muted sm:text-xl" set:html={t.body} />

    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={p('/#quickstart', lang)}
        class="rounded-lg bg-accent px-8 py-3 font-medium text-white transition hover:bg-accent-glow"
      >
        {t.ctaPrimary}
      </a>
      <a
        href={p('/#security', lang)}
        class="rounded-lg border border-border px-8 py-3 font-medium text-text-muted transition hover:border-accent hover:text-text"
      >
        {t.ctaSecondary}
      </a>
    </div>

    <!-- Quick stats -->
    <div class="mt-16 flex flex-wrap items-center justify-center gap-8 text-sm text-text-muted sm:gap-12">
      <div class="flex flex-col items-center">
        <span class="text-2xl font-semibold text-text">{t.stat1Value}</span>
        <span>{t.stat1Label}</span>
      </div>
      <div class="hidden h-8 w-px bg-border sm:block"></div>
      <div class="flex flex-col items-center">
        <span class="text-2xl font-semibold text-text">{t.stat2Value}</span>
        <span>{t.stat2Label}</span>
        <span class="text-xs text-text-muted">{t.stat2Note}</span>
      </div>
      <div class="hidden h-8 w-px bg-border sm:block"></div>
      <div class="flex flex-col items-center">
        <span class="text-2xl font-semibold text-text">{t.stat3Value}</span>
        <span>{t.stat3Label}</span>
        <span class="text-xs text-text-muted">{t.stat3Note}</span>
      </div>
      <div class="hidden h-8 w-px bg-border sm:block"></div>
      <div class="flex flex-col items-center">
        <span class="text-2xl font-semibold text-text">{t.stat4Value}</span>
        <span>{t.stat4Label}</span>
      </div>
    </div>
  </div>
</section>
