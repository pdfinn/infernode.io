---
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 bg-bg/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2 text-lg font-semibold tracking-tight">
      <img src="/nerv-logo.png" alt="NERV logo" class="h-7 w-7 object-contain" />
      <span>InferNode</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-8 text-sm text-text-muted md:flex">
      <a href="/veltro" class="transition hover:text-text">Veltro</a>
      <a href="/compare" class="transition hover:text-text">Compare</a>
      <a href="/#security" class="transition hover:text-text">Security</a>
      <a href="/#how-it-works" class="transition hover:text-text">How It Works</a>
      <a href="/#products" class="transition hover:text-text">The System</a>
      <a href="/#use-cases" class="transition hover:text-text">Use Cases</a>
      <a href="/#quickstart" class="transition hover:text-text">Quick Start</a>
      <a
        href="https://github.com/NERVsystems/infernode"
        class="rounded-md border border-border px-4 py-1.5 transition hover:border-accent hover:text-text"
        target="_blank"
        rel="noopener"
      >
        GitHub
      </a>
    </div>

    <!-- Mobile hamburger button -->
    <button
      id="nav-toggle"
      class="flex h-10 w-10 items-center justify-center rounded-lg text-text-muted transition hover:text-text md:hidden"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <svg id="nav-open-icon" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="nav-close-icon" class="hidden h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="nav-menu" class="hidden border-t border-border/50 bg-bg/95 backdrop-blur-xl md:hidden">
    <div class="flex flex-col gap-1 px-6 py-4 text-sm">
      <a href="/veltro" class="rounded-lg px-3 py-2 text-text-muted transition hover:bg-bg-surface hover:text-text">Veltro</a>
      <a href="/compare" class="rounded-lg px-3 py-2 text-text-muted transition hover:bg-bg-surface hover:text-text">Compare</a>
      <a href="/#security" class="rounded-lg px-3 py-2 text-text-muted transition hover:bg-bg-surface hover:text-text">Security</a>
      <a href="/#how-it-works" class="rounded-lg px-3 py-2 text-text-muted transition hover:bg-bg-surface hover:text-text">How It Works</a>
      <a href="/#products" class="rounded-lg px-3 py-2 text-text-muted transition hover:bg-bg-surface hover:text-text">The System</a>
      <a href="/#use-cases" class="rounded-lg px-3 py-2 text-text-muted transition hover:bg-bg-surface hover:text-text">Use Cases</a>
      <a href="/#quickstart" class="rounded-lg px-3 py-2 text-text-muted transition hover:bg-bg-surface hover:text-text">Quick Start</a>
      <a
        href="https://github.com/NERVsystems/infernode"
        class="mt-2 rounded-lg border border-border px-3 py-2 text-center text-text-muted transition hover:border-accent hover:text-text"
        target="_blank"
        rel="noopener"
      >
        GitHub
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');
  const openIcon = document.getElementById('nav-open-icon');
  const closeIcon = document.getElementById('nav-close-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu when a link is clicked
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
