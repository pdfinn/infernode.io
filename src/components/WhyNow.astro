---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).whyNow;
---

<section class="px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 text-center">
      <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">{t.eyebrow}</p>
      <h2 class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl">
        {t.title}
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-text-muted" set:html={t.intro} />
    </div>

    <div class="grid gap-8 lg:grid-cols-3">
      <div class="rounded-xl border border-border bg-bg-surface p-8">
        <h3 class="mb-3 text-lg font-semibold">{t.t1Title}</h3>
        <p class="text-sm leading-relaxed text-text-muted" set:html={t.t1Body} />
      </div>

      <div class="rounded-xl border border-border bg-bg-surface p-8">
        <h3 class="mb-3 text-lg font-semibold">{t.t2Title}</h3>
        <p class="text-sm leading-relaxed text-text-muted" set:html={t.t2Body} />
      </div>

      <div class="rounded-xl border border-border bg-bg-surface p-8">
        <h3 class="mb-3 text-lg font-semibold">{t.t3Title}</h3>
        <p class="text-sm leading-relaxed text-text-muted" set:html={t.t3Body} />
      </div>
    </div>

    <div class="mt-8 rounded-lg border border-border/50 bg-bg-surface/50 px-6 py-4">
      <p class="text-xs leading-relaxed text-text-muted">
        <strong class="text-text">{t.footnoteLabel}</strong><span set:html={t.footnoteBody} />
      </p>
    </div>
  </div>
</section>
