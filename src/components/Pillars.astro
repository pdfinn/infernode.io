---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).pillars;

const pillars = [
  { ...t.secure, icon: 'ph ph-shield-check' },
  { ...t.sovereign, icon: 'ph ph-flag-banner' },
  { ...t.composable, icon: 'ph ph-squares-four' },
  { ...t.open, icon: 'ph ph-git-fork' },
];
---

<section class="px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        pillars.map((pillar) => (
          <div class="group rounded-xl border border-border bg-bg-surface p-6 transition hover:border-accent/40 hover:bg-bg-surface-hover">
            <i
              class={`${pillar.icon} mb-4 text-2xl text-accent transition group-hover:text-accent-glow`}
            />
            <h3 class="mb-2 text-lg font-semibold">{pillar.title}</h3>
            <p class="text-sm leading-relaxed text-text-muted">{pillar.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
