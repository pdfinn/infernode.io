---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).useCases;

const useCases = [
  { persona: t.u1Persona, headline: t.u1Headline, description: t.u1Body, tags: t.u1Tags },
  { persona: t.u2Persona, headline: t.u2Headline, description: t.u2Body, tags: t.u2Tags },
  { persona: t.u3Persona, headline: t.u3Headline, description: t.u3Body, tags: t.u3Tags },
  { persona: t.u4Persona, headline: t.u4Headline, description: t.u4Body, tags: t.u4Tags },
  { persona: t.u5Persona, headline: t.u5Headline, description: t.u5Body, tags: t.u5Tags },
  { persona: t.u6Persona, headline: t.u6Headline, description: t.u6Body, tags: t.u6Tags },
];
---

<section id="use-cases" class="px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 text-center">
      <p class="mb-4 text-sm font-medium tracking-widest uppercase text-accent">{t.eyebrow}</p>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl" set:html={t.title} />
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        useCases.map((uc) => (
          <div class="rounded-xl border border-border bg-bg-surface p-8 transition hover:border-accent/30">
            <p class="mb-2 text-xs font-medium tracking-widest uppercase text-accent">
              {uc.persona}
            </p>
            <h3 class="mb-3 text-xl font-semibold">{uc.headline}</h3>
            <p class="mb-5 text-sm leading-relaxed text-text-muted">{uc.description}</p>
            <div class="flex flex-wrap gap-2">
              {uc.tags.map((tag) => (
                <span class="rounded-full border border-border px-3 py-1 text-xs text-text-muted">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
